# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Storage ───────────────────────────────────────────────────────────────────
# Absolute path to the SQLite database file (created automatically)
DB_PATH=/var/services/homes/philander/memoryarchiver/data/memoryarchiver.db

# Temporary directory for browser uploads (created automatically, cleaned after encode)
UPLOAD_TEMP_DIR=/var/services/homes/philander/memoryarchiver/backend/uploads

# Root of the RFA archive tree  (must contain Fam/ and Vault/ subdirectories)
NAS_OUTPUT_ROOT=/volume1/RFA

# Root of the scratch browse tree (must contain JNR/ MHR/ CHR/ RAH/ GHR/ subdirectories)
NAS_SCRATCH_ROOT=/volume1/scratch/Pictures

# ── Sync ──────────────────────────────────────────────────────────────────────
# NFS mount point of the sync target. Must contain Fam/ and Vault/ subdirectories.
SYNC_DEST_ROOT=/var/services/homes/noahRFA

# rsync bandwidth limit in KB/s (1024-byte kilobytes).
# 625 ≈ 5 Mbps.  Adjust to taste; does not affect FFmpeg encoding bandwidth.
RSYNC_BWLIMIT_KBPS=625

# ── FFmpeg ────────────────────────────────────────────────────────────────────
# Paths to the ffmpeg and ffprobe binaries.
# On Synology, download the static build from https://johnvansickle.com/ffmpeg/
# and place both binaries somewhere in PATH or set absolute paths here.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Number of threads passed to FFmpeg via -threads.
# On DS220+ (2-core / 4-thread Celeron J4025), 3 leaves headroom for the OS.
FFMPEG_THREADS=3

# nice(1) level for the FFmpeg process (0=normal, 19=lowest priority)
NICE_LEVEL=10

# ── Tesla Fleet API ───────────────────────────────────────────────────────────
# Set TESLA_ENABLED=true to expose Tesla routes and the Garage/Tesla UI.
TESLA_ENABLED=false
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_REDIRECT_URI=
TESLA_FLEET_API_BASE=https://fleet-api.prd.na.vn.cloud.tesla.com
TESLA_AUTH_BASE=https://fleet-auth.prd.vn.cloud.tesla.com
TESLA_PRIVATE_KEY_PATH=/var/services/homes/philander/infra/secrets/tesla_private_key.pem
WEATHER_LAT=41.8827
WEATHER_LON=-87.7538
